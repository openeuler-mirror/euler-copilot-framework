[Unit]
Description=Witty MCP Manager - Universal MCP Host/Loader
Documentation=https://atomgit.com/openeuler/euler-copilot-framework
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/witty-mcp daemon
Restart=on-failure
RestartSec=5s

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/run /var/lib/witty-mcp-manager

# Resource limits
LimitNOFILE=65536
TasksMax=512

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=witty-mcp-manager

[Install]
WantedBy=multi-user.target
